set number
set relativenumber
set tabstop=4
set shiftwidth=4
set expandtab
set ignorecase
set smartcase
set incsearch
set hlsearch
set mouse=a
set undofile
set backspace=indent,eol,start
set splitbelow
set splitright
set showmatch
set wildmenu
set visualbell
set noerrorbells
syntax on
set termguicolors
colorscheme industry
filetype plugin indent on

set undofile
set undodir=~/.vim/undo//

let g:netrw_banner = 0
let g:netrw_liststyle = 3
let g:netrw_winsize = 25
let g:netrw_altv = 1
let g:netrw_fastbrowse = 2

let g:netrw_list_hide = '\(^\|\s\s\)\zs\.\S\+'
let g:netrw_hide = 1
